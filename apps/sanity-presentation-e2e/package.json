{
  "name": "sanity-presentation-e2e",
  "type": "module",
  "private": true,
  "volta": {
    "extends": "../../package.json"
  },
  "scripts": {
    "e2e": "playwright test",
    "e2e-real-studio": "SANITY_E2E_STUDIO_MODE=real-project playwright test real-studio.spec.ts",
    "e2e-real-studio-auth": "SANITY_E2E_STUDIO_MODE=real-project SANITY_E2E_AUTH_SETUP=1 playwright test auth.setup.ts --headed --workers=1",
    "e2e-studio": "SANITY_E2E_STUDIO_MODE=hermetic playwright test real-studio.spec.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@limitless-angular/sanity": "workspace:*",
    "@playwright/test": "1.44.1",
    "@sanity/client": "^7.22.1",
    "@sanity/visual-editing-csm": "^3.0.9",
    "@types/node": "~24.13.2",
    "eslint": "^9.8.0"
  }
}
