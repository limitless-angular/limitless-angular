{
  "name": "sanity-presentation-e2e",
  "type": "module",
  "private": true,
  "scripts": {
    "e2e": "playwright test",
    "e2e-real-studio": "SANITY_E2E_STUDIO_MODE=real-project playwright test real-studio.spec.ts",
