    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "1.44.1",
    "@sanity/client": "^6.21.1",
    "@sanity/visual-editing": "2.10.6",
    "@types/node": "~22.19.20",
    "eslint": "^9.8.0"
  }
}
