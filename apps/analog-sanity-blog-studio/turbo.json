        "SANITY_STUDIO_PROJECT_ID",
        "VITE_SANITY_DATASET",
        "VITE_SANITY_PROJECT_ID"
      ]
    },
    "cors:list": {
      "cache": false,
      "passThroughEnv": [
        "SANITY_STUDIO_DATASET",
        "SANITY_STUDIO_PROJECT_ID",
        "VITE_SANITY_DATASET",
        "VITE_SANITY_PROJECT_ID"
