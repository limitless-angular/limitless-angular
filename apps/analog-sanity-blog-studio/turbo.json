{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env.local"],
      "outputs": ["dist/**"],
      "env": ["SANITY_STUDIO_*"]
    },
    "cors:add": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "cors:list": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "schema:extract": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "seed": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "serve": {
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "setup": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    },
    "typegen": {
      "cache": false,
      "passThroughEnv": ["SANITY_STUDIO_*"]
    }
  }
}
