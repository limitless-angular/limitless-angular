{
  "packageName": "@limitless-angular/sanity",
  "packageRoot": "packages/sanity",
  "artifactDir": ".compat/artifacts",
  "buildAngularMajor": 19,
  "consumerVersionSets": [
    {
      "id": "angular-18-floor",
      "angularMajor": 18,
      "mode": "floor"
    },
    {
      "id": "angular-18-latest",
      "angularMajor": 18,
      "mode": "latest"
    },
    {
      "id": "angular-19-latest",
      "angularMajor": 19,
      "mode": "latest"
    }
  ],
  "canaryVersionSets": [
    {
      "id": "angular-next",
      "npmTag": "next",
      "mode": "dist-tag"
    }
  ],
  "angularPeerDependencies": [
    "@angular/common",
    "@angular/core",
    "@angular/router"
  ],
  "allowBuilds": ["nice-napi"],
  "entrypoints": [
    "@limitless-angular/sanity",
    "@limitless-angular/sanity/shared",
    "@limitless-angular/sanity/image-loader",
    "@limitless-angular/sanity/portabletext",
    "@limitless-angular/sanity/preview-kit",
    "@limitless-angular/sanity/visual-editing"
  ]
}
